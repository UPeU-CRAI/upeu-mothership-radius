# ============================================================================
#  Satellite — Variables específicas de la instancia
#  Usar como base para crear instances/<sede>.env:
#    cp satellite/.env.example satellite/instances/lima.env
# ============================================================================

# Nombre de esta instancia Satellite
SAT_NAME=SAT-LIMA-01
SAT_SHORTNAME=SAT-LIMA-01

# IP local del Satellite en la red del campus
SAT_LOCAL_IP=<IP_LOCAL_SATELLITE>

# --- MOTHERSHIP a la que se conecta -----------------------------------------
MOTHERSHIP_IP=<IP_ELASTICA_AWS>

# Secreto entre este Satellite y la Mothership (debe coincidir con SAT_N_SECRET)
SECRET_SATELLITE_MOTHERSHIP=<GENERAR_CON_dd_if_dev_random>

# --- ACCESS POINTS de esta sede ---------------------------------------------

# Secreto entre los APs locales y este Satellite
SECRET_AP_SATELLITE=<GENERAR_CON_dd_if_dev_random>

# Subred o IP de los APs
AP_SUBNET=<SUBRED_APS>
AP_SHORTNAME=CAMPUS-LIMA-APS

# --- PRUEBAS -----------------------------------------------------------------
TEST_USER=test1
TEST_PASSWORD=<PASSWORD_PRUEBA>
