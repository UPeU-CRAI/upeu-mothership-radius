# ============================================================================
#  Variables GLOBALES — Compartidas entre Mothership y todos los Satellites
#  Estas configuraciones raramente cambian entre instancias
# ============================================================================

# --- TLS --------------------------------------------------------------------
TLS_MIN_VERSION=1.2
TLS_MAX_VERSION=1.2
TLS_CIPHER_LIST=DEFAULT
TLS_CIPHER_LIST_PROD=ECDHE+AESGCM:ECDHE+CHACHA20:!aNULL:!MD5:!DSS
TLS_ECDH_CURVE=prime256v1

# --- CACHÉ TLS --------------------------------------------------------------
TLS_CACHE_LIFETIME=24
TLS_CACHE_MAX_ENTRIES=255
TLS_CACHE_MAX_ENTRIES_PROD=1024

# --- PROXY (aplicado a todos los Satellites) --------------------------------
PROXY_RESPONSE_WINDOW=5
PROXY_ZOMBIE_PERIOD=40
PROXY_REVIVE_INTERVAL=60
PROXY_RESPONSE_TIMEOUTS=3
