# ============================================================================
#  Mothership — Variables específicas de la instancia
#  Copiar a .env y completar con valores reales:
#    cp mothership/.env.example mothership/.env
# ============================================================================

# Nombre del servidor (aparece en logs y certificados)
MOTHERSHIP_HOSTNAME=MOTHERSHIP-AWS

# Elastic IP asignada en AWS
MOTHERSHIP_IP=<IP_ELASTICA_AWS>

# Modo de certificados: "temp" (autofirmados) o "production" (Azure Cloud PKI)
CERT_MODE=temp

# Contraseña de la llave privada (solo si CERT_MODE=production)
CERT_PASSWORD=

# Tipo EAP: "peap" (usuario/contraseña) o "tls" (certificados de dispositivo)
EAP_DEFAULT_TYPE=peap

# Usuario de prueba
TEST_USER=test1
TEST_PASSWORD=<PASSWORD_PRUEBA>

# ============================================================================
#  SATELLITES registrados en esta Mothership
#  Agregar un bloque por cada Satellite que se conecta
# ============================================================================

# --- Satellite Lima ---------------------------------------------------------
SAT_1_NAME=SAT-LIMA-01
SAT_1_SHORTNAME=SAT-LIMA-01
SAT_1_PUBLIC_IP=<IP_PUBLICA_LIMA>
SAT_1_SECRET=<GENERAR_CON_dd_if_dev_random>

# --- Satellite Juliaca (descomentar cuando esté listo) ----------------------
# SAT_2_NAME=SAT-JULIACA-01
# SAT_2_SHORTNAME=SAT-JULIACA-01
# SAT_2_PUBLIC_IP=<IP_PUBLICA_JULIACA>
# SAT_2_SECRET=<GENERAR_CON_dd_if_dev_random>

# --- Satellite Tarapoto (descomentar cuando esté listo) ---------------------
# SAT_3_NAME=SAT-TARAPOTO-01
# SAT_3_SHORTNAME=SAT-TARAPOTO-01
# SAT_3_PUBLIC_IP=<IP_PUBLICA_TARAPOTO>
# SAT_3_SECRET=<GENERAR_CON_dd_if_dev_random>
