# ============================================================================
#  UPeU RADIUS — Variables de Configuración (DATOS REALES)
#  ⚠️  Este archivo NO se sube a Git — contiene secretos
# ============================================================================

# --- MOTHERSHIP (AWS) -------------------------------------------------------
MOTHERSHIP_HOSTNAME=MOTHERSHIP-AWS
MOTHERSHIP_IP=<IP_ELASTICA_AWS>
CERT_MODE=temp
CERT_PASSWORD=
EAP_DEFAULT_TYPE=peap

# --- TLS --------------------------------------------------------------------
TLS_MIN_VERSION=1.2
TLS_MAX_VERSION=1.2
TLS_CIPHER_LIST=DEFAULT
TLS_CIPHER_LIST_PROD=ECDHE+AESGCM:ECDHE+CHACHA20:!aNULL:!MD5:!DSS
TLS_ECDH_CURVE=prime256v1

# --- CACHÉ TLS --------------------------------------------------------------
TLS_CACHE_LIFETIME=24
TLS_CACHE_MAX_ENTRIES=255
TLS_CACHE_MAX_ENTRIES_PROD=1024

# --- SATELLITE ---------------------------------------------------------------
SAT_NAME=SAT-LIMA-01
SAT_SHORTNAME=SAT-LIMA-01
SAT_PUBLIC_IP=<IP_PUBLICA_SEDE>
SAT_LOCAL_IP=<IP_LOCAL_SATELLITE>

# --- SECRETOS ----------------------------------------------------------------
SECRET_SATELLITE_MOTHERSHIP=<GENERAR_CON_dd_if_dev_random>
SECRET_AP_SATELLITE=<GENERAR_CON_dd_if_dev_random>

# --- ACCESS POINTS -----------------------------------------------------------
AP_SUBNET=<SUBRED_APS>
AP_SHORTNAME=CAMPUS-LIMA-APS

# --- PROXY -------------------------------------------------------------------
PROXY_RESPONSE_WINDOW=5
PROXY_ZOMBIE_PERIOD=40
PROXY_REVIVE_INTERVAL=60
PROXY_RESPONSE_TIMEOUTS=3

# --- USUARIO DE PRUEBA -------------------------------------------------------
TEST_USER=test1
TEST_PASSWORD=<PASSWORD_PRUEBA>

# --- UNIFI CONTROLLER --------------------------------------------------------
UNIFI_CONTROLLER_IP=<IP_UNIFI_CONTROLLER>
UNIFI_SSID_NAME=UPeU-Secure
